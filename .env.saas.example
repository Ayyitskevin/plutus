# Plutus Cloud — dedicated SaaS deploy (separate from homelab on :8030)
# Copy to .env:  cp .env.saas.example .env  &&  edit secrets

PLUTUS_SAAS_MODE=true
PLUTUS_SIGNUP_ENABLED=true
PLUTUS_SIGNUP_TRIAL_DAYS=14
PLUTUS_SIGNUP_TRIAL_RECOMMEND_CAP=25
# PLUTUS_SIGNUP_REDIRECT_BILLING=true
PLUTUS_HOST=0.0.0.0
PLUTUS_PORT=8031
PLUTUS_SAAS_PUBLIC_URL=http://127.0.0.1:8031
PLUTUS_DATA_DIR=/var/lib/plutus/data
# Optional Postgres (omit to use SQLite at PLUTUS_DATA_DIR/plutus.db)
# PLUTUS_DATABASE_URL=postgresql://plutus:secret@127.0.0.1:5432/plutus

# Auth (generate unique values)
PLUTUS_API_TOKEN=CHANGE_ME_ADMIN_TOKEN
PLUTUS_TENANT_KEY_PEPPER=CHANGE_ME_DISTINCT_PEPPER

# Ops
PLUTUS_RATE_LIMIT_ENABLED=true
PLUTUS_RATE_LIMIT_PER_MINUTE=120
PLUTUS_RATE_LIMIT_RECOMMEND_PER_MINUTE=30
PLUTUS_AUDIT_LOG_ENABLED=true
PLUTUS_PROMETHEUS_ENABLED=true
PLUTUS_STRUCTURED_LOGS=true
# PLUTUS_REDIS_URL=redis://127.0.0.1:6379/0

# Tenant gallery uploads (local disk default; S3 for production)
# PLUTUS_STORAGE_BACKEND=s3
# PLUTUS_S3_BUCKET=plutus-tenant-galleries
# PLUTUS_S3_REGION=us-east-1
# PLUTUS_S3_ACCESS_KEY=
# PLUTUS_S3_SECRET_KEY=
# PLUTUS_S3_PREFIX=plutus/tenants
# PLUTUS_MAX_UPLOAD_FILES=50
# PLUTUS_MAX_UPLOAD_FILE_BYTES=26214400
# PLUTUS_CORS_ORIGINS=https://app.example.com

# Mise integration (optional — per-tenant recommend from published galleries)
# PLUTUS_MISE_URL=http://flow:8400
# PLUTUS_MISE_API_TOKEN=
# PLUTUS_MISE_MEDIA_ROOT=/path/to/mise-media

# Argus vision — auto-runs on upload analyze when configured (grok/xAI on homelab)
PLUTUS_ARGUS_URL=http://127.0.0.1:8010
PLUTUS_ARGUS_TOKEN=CHANGE_ME_SAME_AS_ARGUS_API_TOKEN
PLUTUS_ARGUS_AUTO_VISION=true
PLUTUS_ARGUS_ANALYZE_LIMIT=10
PLUTUS_ARGUS_TIMEOUT=600

# Stripe — tenant subscriptions + client bundle checkout
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID=price_CHANGE_ME
# Local dogfood without a test card (sk_test_ keys only):
# PLUTUS_ALLOW_SIMULATE_PAYMENT=true

# Async upload analyze (default on — Argus vision runs in background worker)
# PLUTUS_UPLOAD_ASYNC_ANALYZE=true
# PLUTUS_UPLOAD_WORKER_INTERVAL=2

# Real Stripe local webhook forward:
#   bash scripts/stripe-listen.sh
#   copy whsec_... → STRIPE_WEBHOOK_SECRET
# Full test checkout dogfood:
#   bash scripts/dogfood-stripe-real.sh

# Webhook forward (local dev):
#   stripe listen --forward-to localhost:8031/webhooks/stripe

# Lab + order notifications
PLUTUS_LAB_ADAPTER=mock
PLUTUS_LAB_MOCK_PROCESS_SECONDS=120
PLUTUS_LAB_MOCK_SHIP_SECONDS=600
# PLUTUS_LAB_ADAPTER=whcc
# WHCC_API_URL=https://api.whcc.com/v1
# WHCC_API_KEY=
# WHCC_ACCOUNT_ID=
# WHCC_WEBHOOK_SECRET=
# PLUTUS_ORDER_ALERT_EMAIL=ops@example.com
# PLUTUS_ORDER_WEBHOOK_URL=https://hooks.example.com/plutus-orders
# PLUTUS_SMTP_HOST=smtp.example.com
# PLUTUS_SMTP_PORT=587
# PLUTUS_SMTP_USER=
# PLUTUS_SMTP_PASSWORD=
# PLUTUS_SMTP_FROM=plutus@example.com