# Plutus homelab — mickey / strix-halo (pairs with Mise on flow)
PLUTUS_HOST=0.0.0.0
PLUTUS_PORT=8030
PLUTUS_DATA_DIR=/home/kevin-lee/ai-workspace/plutus/data-homelab
# Leave empty for SQLite; set only if homelab should share Postgres (unusual)
PLUTUS_DATABASE_URL=

# Inbound bearer for Mise → POST /recommend/mise-gallery
PLUTUS_API_TOKEN=CHANGE_ME_SHARED_WITH_MISE

# Mise on flow:8400
PLUTUS_MISE_URL=http://flow:8400
PLUTUS_MISE_API_TOKEN=CHANGE_ME_SAME_AS_MISE_ARGUS_TOKEN
PLUTUS_MISE_MEDIA_ROOT=/home/kevin-lee/ai-workspace/argus/data/mise-media

# Argus keeper/hero enrichment
PLUTUS_ARGUS_URL=http://strix-halo-a9-mega:8010
PLUTUS_ARGUS_TOKEN=CHANGE_ME_SAME_AS_ARGUS_API_TOKEN

# Homelab stays single-tenant (SaaS off)
PLUTUS_SAAS_MODE=false

# Client storefront + checkout on :8030
PLUTUS_HOMELAB_STORE_ENABLED=true
PLUTUS_SAAS_PUBLIC_URL=http://127.0.0.1:8030
PLUTUS_ALLOW_SIMULATE_PAYMENT=true
PLUTUS_LAB_ADAPTER=mock
STRIPE_SECRET_KEY=sk_test_CHANGE_ME

# Dionysus pitch enrichment (optional — scripts/wire-dionysus-homelab.sh)
# PLUTUS_DIONYSUS_URL=http://127.0.0.1:8450
# PLUTUS_DIONYSUS_TOKEN=<same as DIONYSUS_MISE_IMPORT_TOKEN>
# PLUTUS_DIONYSUS_ORG_SLUG=blue-plate

# Order notifications when paid / lab shipped
# PLUTUS_ORDER_WEBHOOK_URL=https://hooks.example/plutus
# PLUTUS_ORDER_ALERT_EMAIL=studio@example.com
# PLUTUS_NOTIFY_LAB_SHIPPED=true

# On flow Mise .env (deploy separately):
# MISE_PLUTUS_URL=http://strix-halo-a9-mega:8030
# MISE_PLUTUS_TOKEN=<same as PLUTUS_API_TOKEN>