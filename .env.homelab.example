# Plutus studio — Mise admin print/album upsell (mickey / strix-halo, Mise on flow)
PLUTUS_HOST=0.0.0.0
PLUTUS_PORT=8030
PLUTUS_DATA_DIR=/home/kevin-lee/ai-workspace/plutus/data-homelab
PLUTUS_PUBLIC_URL=http://127.0.0.1:8030
# Back-link from /runs/{id} to Mise gallery admin
# PLUTUS_MISE_ADMIN_URL=http://flow:8400

# Inbound bearer for Mise → POST /recommend/mise-gallery.
# Must equal MISE_PLUTUS_TOKEN in Mise's .env (the same shared secret).
PLUTUS_API_TOKEN=CHANGE_ME_SHARED_WITH_MISE
# Optional: extra accepted tokens (comma-separated) so a rotation keeps the OLD
# and NEW secret valid at once — set NEW here, swap Mise, then drop the OLD.
# PLUTUS_SERVICE_TOKENS=

# Mise on flow:8400
PLUTUS_MISE_URL=http://flow:8400
PLUTUS_MISE_API_TOKEN=CHANGE_ME_SAME_AS_MISE_ARGUS_TOKEN
PLUTUS_MISE_MEDIA_ROOT=/home/kevin-lee/ai-workspace/argus/data/mise-media

# Argus keeper/hero enrichment
PLUTUS_ARGUS_URL=http://strix-halo-a9-mega:8010
PLUTUS_ARGUS_TOKEN=CHANGE_ME_SAME_AS_ARGUS_API_TOKEN

# No client checkout — review bundles in Plutus UI, copy pitch.txt into client email
PLUTUS_HOMELAB_STORE_ENABLED=false

# On flow Mise .env (deploy separately):
# MISE_PLUTUS_URL=http://strix-halo-a9-mega:8030
# MISE_PLUTUS_TOKEN=<same as PLUTUS_API_TOKEN>